{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Plume main window — minimal IPC surface per docs/SPEC.md. fs scope is granted dynamically via dialog selection (persisted by plugin-persisted-scope), never declared globally here.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-title",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-message",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "store:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    },
    "allow-grant-scope",
    "allow-get-opened-urls",
    "allow-list-codex-files"
  ]
}
